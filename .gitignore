# ─────────────────────────────────────────────────────────────
# TechSpecs / SiMPL XStep project .gitignore
#
# Keep the deliverables (mock-up image.png, *.docx specs, EBR PDFs,
# the build scripts under _scratch/) and ignore only regenerable
# build intermediates, caches, and OS/editor cruft.
# ─────────────────────────────────────────────────────────────

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
# virtual environments
.venv/
venv/
env/
ENV/
.python-version

# --- Build intermediates (regenerated by the mock-up / EBR / spec scripts) ---
# Generated HTML scratch files (the PDFs/PNGs in the deliverable folders are kept)
_scratch/**/*.html
_scratch/mockups/html/
# Per-mock-up temp render HTML (build_az3.py "mk_*.html", build_mockups html/)
mk_*.html
# In-place docx build temp copies + Office lock files
*.tmp
~$*
# Local FM/interface backups taken before in-place spec edits
_scratch/backups/

# --- OS cruft ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
desktop.ini
$RECYCLE.BIN/

# --- Editors / IDE ---
.idea/
*.swp
*.swo
*~
# VS Code: keep shared settings, ignore per-user state
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# --- Claude Code (keep shared project config, ignore local overrides) ---
.claude/settings.local.json
.claude/**/local/
